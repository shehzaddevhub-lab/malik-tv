        .unselectable { -webkit-user-select: none; user-select: none; -webkit-touch-callout: none; }

        /* --- PLAYER SECTION --- */
        #player-wrapper {
            flex: 2; /* Takes 2/3 space on large screens */
            background: #000; position: relative; z-index: 1000;
            display: flex; flex-direction: column; 
            border-right: 2px solid var(--gold);
            border-bottom: none;
        }

        .now-playing { 
            padding: 8px; font-size: 13px; font-weight: bold; color: var(--gold); 
            text-align: left; padding-left: 15px; background: rgba(0,0,0,0.8); letter-spacing: 1px;
            position: absolute; top: 0; left: 0; right: 50px; z-index: 10;
            border-bottom-right-radius: 15px;
        }

        /* --- INSTALL BUTTONS (TOP RIGHT) --- */
        .install-buttons {
            position: absolute; top: 8px; right: 55px; z-index: 15;
            display: flex; gap: 8px;
        }
        
        .header-btn {
            background: var(--gold); color: #000; border: 1px solid #fff;
            padding: 4px 10px; border-radius: 6px; cursor: pointer; outline: none;
            font-weight: bold; font-size: 12px; transition: 0.3s;
            text-decoration: none; display: flex; align-items: center; justify-content: center;
        }
        .header-btn:hover { background: #fff; color: var(--dark-red); }
        
        #installWebBtn { display: none; /* Hidden until PWA is ready */ }

        /* --- SMART PiP BUTTON --- */
        .pip-btn {
            position: absolute; top: 8px; right: 15px; z-index: 15;
            background: rgba(0,0,0,0.6); color: var(--white); border: 1px solid var(--gold);
            padding: 4px 8px; border-radius: 6px; cursor: pointer; outline: none;
            display: none; 
            transition: 0.3s; align-items: center; justify-content: center;
        }
        .pip-btn:active, .pip-btn:focus { background: var(--gold); color: #000; }
        .pip-btn svg { width: 18px; height: 18px; fill: currentColor; }

        .video-container {
            width: 100%; height: 100%; background: #000; position: relative;
            display: flex; align-items: center; justify-content: center;
        }
        
        /* Disable Native Controls Pointer Events */
        video { width: 100%; height: 100%; object-fit: contain; transition: 0.2s; pointer-events: none; }
        .video-fill { object-fit: fill !important; }

        .click-shield-main { position: absolute; top: 0; bottom: 0; left: 0; right: 50px; z-index: 5; }
        .click-shield-bottom { position: absolute; top: 50px; bottom: 0; right: 0; width: 50px; z-index: 5; }

        /* NATIVE CONTROLS HIDE */
        video::-webkit-media-controls { display: none !important; }

        .player-loader {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 45px; height: 45px; border: 4px solid rgba(255, 255, 255, 0.2);
            border-top: 4px solid var(--gold); border-radius: 50%;
            animation: spin 1s linear infinite; z-index: 20; display: none;
        }
        @keyframes spin { 100% { transform: translate(-50%, -50%) rotate(360deg); } }

        .overlay-ui { opacity: 0; visibility: hidden; transition: opacity 0.3s ease, visibility 0.3s ease; }
        #player-wrapper.active-controls .overlay-ui, #player-wrapper:hover .overlay-ui { opacity: 1; visibility: visible; }

        /* --- CUSTOM TOOLS BAR --- */
        .tools-bar {
            position: absolute; bottom: 0; left: 0; width: 100%;
            display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
            padding: 10px 5px; background: rgba(0,0,0,0.85); border-top: 1px solid rgba(255, 215, 0, 0.5);
            z-index: 100;
        }

        .tools-left { display: flex; gap: 6px; align-items: center; justify-self: start; }
        .tools-center { display: flex; align-items: center; justify-self: center; }
        .tools-right { display: flex; gap: 6px; align-items: center; justify-self: end; }

        /* FIX: White text on Gold background issue resolved */
        .btn, .quality-select {
            background: rgba(255,255,255,0.15); color: var(--white); border: 1px solid var(--gold);
            padding: 8px 12px; border-radius: 6px; font-size: 12px; cursor: pointer; font-weight: bold; outline: none;
            display: flex; align-items: center; justify-content: center; white-space: nowrap; pointer-events: auto;
        }
        .btn:active, .btn:focus, .quality-select:focus { 
            background: var(--gold); 
            color: #000 !important; /* Force text to black when background is gold */
        }
        .play-btn { font-size: 16px; padding: 8px 24px; }

        .toast-msg {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(220, 0, 0, 0.95); color: white; padding: 20px; border-radius: 12px;
            font-size: 15px; font-weight: bold; border: 2px solid var(--gold); z-index: 999999;
            opacity: 0; visibility: hidden; text-align: center; width: 85%; max-width: 350px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8); pointer-events: none;
        }
        .toast-msg.show { 
            opacity: 1; visibility: visible; 
            animation: blinkPopup 0.8s infinite alternate; 
        }
        @keyframes blinkPopup {
            0% { box-shadow: 0 0 10px var(--gold); transform: translate(-50%, -50%) scale(1); }
            100% { box-shadow: 0 0 30px var(--gold); transform: translate(-50%, -50%) scale(1.05); color: var(--gold); }
        }

