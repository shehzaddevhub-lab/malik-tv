        .channel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 10px; margin-bottom: 10px; }

        .channel-card { 
            background: var(--glass-bg); border: 1px solid rgba(255, 215, 0, 0.3); 
            border-radius: 12px; padding: 15px 5px; text-align: center; cursor: pointer; transition: 0.3s; 
            outline: none; /* Important for TV Focus */
        }
        
        /* TV Remotes / PC Keyboard Navigation Focus */
        .channel-card:focus, .channel-card:hover {
            border-color: #fff; transform: scale(1.05); background: rgba(255, 215, 0, 0.3); box-shadow: 0 0 10px var(--gold);
