        #channels-wrapper { 
            flex: 1; /* Takes 1/3 space on large screens */
            overflow-y: auto; display: flex; flex-direction: column; position: relative; 
            background: rgba(0,0,0,0.2); min-width: 320px;
        }
        
        .list-container { padding: 15px; }

