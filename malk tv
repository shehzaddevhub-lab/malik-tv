        .channel-card span { font-size: 11px; font-weight: bold; display: block; margin-top: 5px; }
        .channel-card .icon { font-size: 24px; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 5px; }

        .footer-info { text-align: center; padding: 30px 10px 20px 10px; font-size: 12px; font-weight: 600; letter-spacing: 1.2px; color: var(--footer-gray); text-transform: uppercase; margin-top: auto; }
