        const container = document.getElementById("channels-container");

        // --- SEARCH & RENDER CHANNELS ---
        function renderChannels(filterText = "") {
            let html = "";
            let currentCategory = "";
            let count = 0;
            
            channelsData.forEach((ch, index) => {
                if(ch.name.toLowerCase().includes(filterText.toLowerCase())) {
                    if (!filterText && ch.cat !== currentCategory) {
                        if (html !== "") html += `</div>`;
                        html += `<div class="category-title">${ch.cat}</div><div class="channel-grid">`;
                        currentCategory = ch.cat;
                    } else if (filterText && currentCategory === "") {
                        html += `<div class="channel-grid">`;
                        currentCategory = "search";
                    }
                    // ADDED tabindex="0" and onkeypress FOR SMART TV/PC KEYBOARD SUPPORT
                    html += `<div class="channel-card" id="card-${index}" tabindex="0" onclick="playChannel('${ch.url}', '${ch.name}', 'card-${index}')" onkeypress="if(event.key==='Enter') playChannel('${ch.url}', '${ch.name}', 'card-${index}')">
                                <div class="icon">${ch.icon}</div><span>${ch.name}</span>
                             </div>`;
                    count++;
                }
            });
            if (html !== "") html += `</div>`;
            if (count === 0) html = `<div style="text-align:center; padding: 20px; color:var(--gold);">Koi channel nahi mila!</div>`;
            container.innerHTML = html;
        }

        renderChannels(); // Initial Load

        // PLAYER LOGIC
        const video = document.getElementById('videoPlayer');
        const loader = document.getElementById('playerLoader');
        const playBtn = document.getElementById('playBtn');
        let hls;

        // --- SMART PiP LOGIC ---
        const pipBtn = document.getElementById('pipBtn');
        if ('pictureInPictureEnabled' in document && document.pictureInPictureEnabled) {
            pipBtn.style.display = 'flex'; // Show if natively supported
        }

        async function togglePiP() {
            try {
                if (video !== document.pictureInPictureElement) {
                    await video.requestPictureInPicture();
                } else {
                    await document.exitPictureInPicture();
                }
            } catch (error) {
                console.log("PiP Failed:", error);
            }
        }

        video.addEventListener('waiting', () => loader.style.display = 'block');
        video.addEventListener('playing', () => { loader.style.display = 'none'; playBtn.innerText = "⏸"; });
        video.addEventListener('pause', () => playBtn.innerText = "▶");
        video.addEventListener('canplay', () => loader.style.display = 'none');

        // Play Channel
        function playChannel(url, name, cardId, isInitial = false) {
            document.getElementById('nowPlayingText').innerText = "🔴 Playing: " + name;
            loader.style.display = 'block'; 
            
            document.querySelectorAll('.channel-card').forEach(c => c.classList.remove('active-playing'));
            if(cardId) {
                const activeCard = document.getElementById(cardId);
                if(activeCard) activeCard.classList.add('active-playing');
            }

            try {
                if (typeof Hls !== 'undefined' && Hls.isSupported()) {
                    if (hls) { hls.destroy(); }
                    hls = new Hls();
                    hls.loadSource(url);
                    hls.attachMedia(video);
                    hls.on(Hls.Events.MANIFEST_PARSED, function(event, data) {
                        
                        video.muted = false; // 100% Volume
                        video.play().catch(e => {
                            console.log("Auto-play blocked by browser.");
                            playBtn.innerText = "▶";
                        });

                        const qSelect = document.getElementById('qualitySelector');
                        qSelect.innerHTML = '<option value="-1">Auto</option>';
                        data.levels.forEach((level, index) => {
                            qSelect.innerHTML += `<option value="${index}">${level.height}p</option>`;
                        });
                    });
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = url;
                    video.muted = false;
                    video.play();
                } else {
                    loader.style.display = 'none';
                }
            } catch(e) {
                loader.style.display = 'none';
                console.log("Offline mode or HLS script missing.");
            }
            
            // Only scroll into view if on mobile layout, prevent jumping on PC
            if(!isInitial && cardId && window.innerWidth <= 768) {
                const el = document.getElementById(cardId);
                if(el) { setTimeout(() => { el.scrollIntoView({ behavior: "smooth", block: "center" }); }, 100); }
            }
        }

        function changeQuality(level) { if (hls) hls.currentLevel = parseInt(level); }

        // --- CUSTOM PLAY / PAUSE ---
        function togglePlayPause() {
            if (video.paused) video.play();
            else video.pause();
        }

        // --- CUSTOM MUTE / UNMUTE ---
        function toggleVolume() {
            const volBtn = document.getElementById('volBtn');
            if (video.muted) {
                video.muted = false;
                volBtn.innerText = "🔊";
            } else {
                video.muted = true;
                volBtn.innerText = "🔇";
            }
        }

        // --- TOGGLE CONTROLS LOGIC (TAP SHOW/HIDE ONLY) ---
        const playerWrapper = document.getElementById('player-wrapper');
        let hideTimeout;
        
        function toggleControls() {
            if (playerWrapper.classList.contains('active-controls')) {
                playerWrapper.classList.remove('active-controls');
                clearTimeout(hideTimeout);
            } else {
                playerWrapper.classList.add('active-controls');
                clearTimeout(hideTimeout);
                // Hide after 3 seconds
                hideTimeout = setTimeout(() => { playerWrapper.classList.remove('active-controls'); }, 3000); 
            }
        }

        function showControlsTemp() {
            playerWrapper.classList.add('active-controls');
            clearTimeout(hideTimeout);
            hideTimeout = setTimeout(() => { playerWrapper.classList.remove('active-controls'); }, 3000); 
        }

        // --- EXTEND / FILL SCREEN ---
        let isFit = false;
        function toggleFit() {
            const fitBtn = document.getElementById('fitBtn');
            if(!isFit) {
                video.classList.add("video-fill");
                fitBtn.innerText = "⏏ Reset"; fitBtn.style.color = "var(--gold)";
                isFit = true;
            } else {
                video.classList.remove("video-fill");
                fitBtn.innerText = "↔ Extend"; fitBtn.style.color = "var(--white)";
                isFit = false;
            }
        }

        // --- SHOW ROTATE WARNING (BLINKING 6.5 SECONDS) ---
        function showWarningToast() {
            // Only show on mobile
            if(window.innerWidth <= 768) {
                const toast = document.getElementById('rotateWarning');
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 6500); // Blinks for 6.5 seconds
            }
        }

        // --- FULL SCREEN LOGIC (TRUE FULLSCREEN FOR PC/TV) ---
        let isCinemaMode = false;
        function toggleCinemaMode() {
            const wrapper = document.body; // Fullscreen the entire body
            const btn = document.getElementById('cinemaBtn');

            if (!isCinemaMode) {
                showWarningToast(); // Warning Message Center Popup (Mobile only)

                if (wrapper.requestFullscreen) {
                    wrapper.requestFullscreen().then(() => {
                        if (screen.orientation && screen.orientation.lock && window.innerWidth <= 768) {
                            screen.orientation.lock('landscape').catch(e => { forceCSSRotate(document.getElementById('player-wrapper')); });
                        } 
                        // Do not force CSS rotate on PC
                    }).catch(err => { if(window.innerWidth <= 768) forceCSSRotate(document.getElementById('player-wrapper')); });
                } else if (wrapper.webkitRequestFullscreen) { /* Safari */
                    wrapper.webkitRequestFullscreen();
                } else if (wrapper.msRequestFullscreen) { /* IE11 */
                    wrapper.msRequestFullscreen();
                } else if(window.innerWidth <= 768) { forceCSSRotate(document.getElementById('player-wrapper')); }
                
                btn.innerText = "⏏ EXIT FULL ↻"; btn.style.color = "var(--gold)";
                isCinemaMode = true;
            } else {
                if (document.exitFullscreen) { document.exitFullscreen().catch(e => console.log(e)); }
                else if (document.webkitExitFullscreen) { document.webkitExitFullscreen(); }
                else if (document.msExitFullscreen) { document.msExitFullscreen(); }
                if (screen.orientation && screen.orientation.unlock) { screen.orientation.unlock(); }
                removeCSSRotate(document.getElementById('player-wrapper'));
                btn.innerText = "⛶ Full Screen ↻"; btn.style.color = "var(--white)";
                isCinemaMode = false;
            }
        }

        function forceCSSRotate(wrapper) {
            if(window.innerWidth <= 768) {
                wrapper.classList.add("css-force-landscape");
                document.getElementById('channels-wrapper').classList.add("hide-list");
            }
        }
        function removeCSSRotate(wrapper) {
            wrapper.classList.remove("css-force-landscape");
            document.getElementById('channels-wrapper').classList.remove("hide-list");
        }

        // Listen for user pressing ESC key to exit fullscreen
        document.addEventListener('fullscreenchange', exitHandler);
        document.addEventListener('webkitfullscreenchange', exitHandler);
        document.addEventListener('mozfullscreenchange', exitHandler);
        document.addEventListener('MSFullscreenChange', exitHandler);

        function exitHandler() {
            if (!document.fullscreenElement && !document.webkitIsFullScreen && !document.mozFullScreen && !document.msFullscreenElement) {
                if (screen.orientation && screen.orientation.unlock) screen.orientation.unlock();
                removeCSSRotate(document.getElementById('player-wrapper'));
                isCinemaMode = false;
                const btn = document.getElementById('cinemaBtn');
                if(btn){
                     btn.innerText = "⛶ Full Screen ↻";
                     btn.style.color = "var(--white)";
                }
            }
        }

        // Prevent accidental zoom (Mobile)
        document.addEventListener('touchstart', (e) => { if (e.touches.length > 1) e.preventDefault(); }, { passive: false });

        // --- RANDOM CHANNEL AUTO-PLAY ON START WITH FULL SOUND ---
        document.addEventListener("DOMContentLoaded", () => {
            if(channelsData && channelsData.length > 0) {
                
                video.muted = false; 
                document.getElementById('volBtn').innerText = "🔊";
                
                const randomIndex = Math.floor(Math.random() * channelsData.length);
                const randomChannel = channelsData[randomIndex];
                const cardId = 'card-' + randomIndex;

                // Pass 'true' to prevent auto-scrolling
                playChannel(randomChannel.url, randomChannel.name, cardId, true);
                
                showControlsTemp();
            }
        });

    </script>
</body>
</html>
